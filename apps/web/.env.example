# NextSpot 프론트엔드 환경변수 (apps/web) — 로컬 전용
# 실제 값은 apps/web/.env.local 에 넣는다(gitignore). NEXT_PUBLIC_ 접두는 브라우저 번들에 포함된다.

# --- Supabase (주 데이터/인증) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Kakao Maps SDK (지도) ---
# 코드는 NEXT_PUBLIC_KAKAO_MAPS_APP_KEY 를 우선 읽고 NEXT_PUBLIC_KAKAO_MAP_KEY 로 폴백한다.
NEXT_PUBLIC_KAKAO_MAPS_APP_KEY=your-kakao-maps-app-key
# (선택) 도보/차량 실거리 길찾기. 미설정 시 직선거리 환산 폴백.
NEXT_PUBLIC_KAKAO_REST_API_KEY=your-kakao-rest-api-key

# --- 백엔드(FastAPI) ---
# 로컬 백엔드 주소. 미설정 시 http://localhost:8000 기본값.
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000
