# NextSpot API 환경변수 (apps/api) — 로컬 전용
# 복사: cp .env.example .env  후 Supabase 값 채우기.

# --- App Configuration ---
ENV=development
PROJECT_NAME="NextSpot API"

# --- Supabase Configuration (주 데이터 저장소) ---
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Secret: Supabase JWT 검증용 (Gotrue JWT Secret)
# Supabase Project settings -> API -> JWT Secret 에서 획득 가능
JWT_SECRET=your-supabase-jwt-secret

# --- 관리자 가드 토큰 (필수 — 미설정 시 부팅 실패) ---
# 프런트(apps/web) NEXT_PUBLIC_ADMIN_API_TOKEN 과 동일한 값이어야 한다.
# 로컬 데모는 아래 값 그대로 사용 가능. 공개 배포 시에는 반드시 강한 랜덤값으로 교체할 것
# (예: openssl rand -hex 32). 저장소에 커밋된 값은 비밀이 아니다.
ADMIN_API_TOKEN=nextspot-admin-local

# --- Kakao Mobility Directions API (선택) ---
# 설정 시 후보 시설까지 실거리/실시간 이동시간을 사용. 비우면 Haversine 직선거리 도보 환산으로 폴백.
KAKAO_REST_API_KEY=

# --- 관광 데이터 API ---
# 한국관광공사 TourAPI(공공데이터포털 B551011) 인증키 — 공모전 필수 데이터.
# POI 적재(scripts/ingest_tourapi.py)와 행사 조회에 사용.
TOURAPI_KEY=

# (예정) Tmap 도보 경로 API — WS-C에서 travel.py 어댑터로 사용 예정.
TMAP_APP_KEY=

# 경주 황리단길 기준좌표: 위도 35.8361 / 경도 129.2105 (scripts/ingest_tourapi.py 의 --lat/--lng 기본값)

# --- CORS Configuration ---
# 쉼표(,)로 구분된 허용 도메인 목록. 실제 도메인을 지정하면 해당 오리진만 허용 + credentials 활성(엄격 모드).
# "*" 또는 미설정이면 모든 오리진 허용(credentials 끔).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
