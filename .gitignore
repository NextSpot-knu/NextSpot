# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
out/
apps/web/out/
apps/web/.next/
apps/web/api_backup/
api_backup/

# firebase
.firebase/
.firebase/*

# production
/build
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
__pycache__/
*.pyc
*.pyo
*.pkl
# setuptools sdist 부산물(Dataflow --setup_file 빌드가 dataflow/ 에 생성)
*.egg-info/

# Python 가상환경
.venv/
.venv_beam/
poetry.toml

# WP1 Vertex 배포 임시 산출물 (재생성 가능)
*.joblib
.venv_deploy/
apps/api/scripts/_model_coef.json
apps/api/redeploy.log
apps/api/deploy_vertex.log

# supabase cli temp
supabase/.temp/
scratch/

# GCP service-account key files (never commit plaintext SA keys).
# Scoped to repo root so the broad dotted-JSON glob can't swallow nested config JSON that must stay tracked.
/*-*.json
/knudc-*.json

# Stray env files beyond the committed .example templates (belt-and-suspenders; .env* already ignored above)
*.env
!*.env.example